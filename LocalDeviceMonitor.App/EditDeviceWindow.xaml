<Window x:Class="LocalDeviceMonitor.App.EditDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Dispositivo" Height="650" Width="500" WindowStartupLocation="CenterOwner" Background="#EEF3F9">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" Margin="10" VerticalScrollBarVisibility="Auto">
            <StackPanel Background="White" Margin="10">
                <TextBlock Text="✏️ Editar Detalhes do Dispositivo" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

                <TextBlock Text="Nome do Dispositivo" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="NameTextBox" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Origem (Ex: LAN, WIFI, BACNET)" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="OriginTextBox" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Tipo de Dispositivo" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="DeviceTypeTextBox" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Fabricante" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="ManufacturerTextBox" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="IP Address" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="IpTextBox" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="MAC Address" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="MacTextBox" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Portas Abertas" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="PortsTextBox" Height="30" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Classificação / Atributo" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="AtributoCombo" DisplayMemberPath="Nome" Height="35" Margin="0,0,0,15"/>

                <TextBlock Text="Notas Adicionais" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="NotesTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Padding="5" Margin="0,0,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancelar" Height="40" Background="#E2E8F0" Foreground="#475569" FontWeight="Bold" Click="Cancel_Click" BorderThickness="0"/>
            <Button Grid.Column="2" Content="Gravar Alterações" Height="40" Background="#2563EB" Foreground="White" FontWeight="Bold" Click="Save_Click" BorderThickness="0"/>
        </Grid>
    </Grid>
</Window>
